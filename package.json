{
  "name": "@hsablonniere/musiq",
  "version": "0.0.3",
  "description": "Web components for rendering musical instruments, chords, and scales",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "sideEffects": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mq-piano": {
      "types": "./dist/mq-piano/mq-piano.d.ts",
      "import": "./dist/mq-piano/mq-piano.js",
      "default": "./dist/mq-piano/mq-piano.js"
    },
    "./mq-piano-chord": {
      "types": "./dist/mq-piano-chord/mq-piano-chord.d.ts",
      "import": "./dist/mq-piano-chord/mq-piano-chord.js",
      "default": "./dist/mq-piano-chord/mq-piano-chord.js"
    },
    "./mq-piano-scale": {
      "types": "./dist/mq-piano-scale/mq-piano-scale.d.ts",
      "import": "./dist/mq-piano-scale/mq-piano-scale.js",
      "default": "./dist/mq-piano-scale/mq-piano-scale.js"
    },
    "./mq-fretboard": {
      "types": "./dist/mq-fretboard/mq-fretboard.d.ts",
      "import": "./dist/mq-fretboard/mq-fretboard.js",
      "default": "./dist/mq-fretboard/mq-fretboard.js"
    },
    "./mq-fretboard-chord": {
      "types": "./dist/mq-fretboard-chord/mq-fretboard-chord.d.ts",
      "import": "./dist/mq-fretboard-chord/mq-fretboard-chord.js",
      "default": "./dist/mq-fretboard-chord/mq-fretboard-chord.js"
    },
    "./mq-fretboard-scale": {
      "types": "./dist/mq-fretboard-scale/mq-fretboard-scale.d.ts",
      "import": "./dist/mq-fretboard-scale/mq-fretboard-scale.js",
      "default": "./dist/mq-fretboard-scale/mq-fretboard-scale.js"
    }
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt src/",
    "lint": "oxlint src/",
    "typecheck": "tsgo --noEmit",
    "cem": "cem analyze",
    "prepublishOnly": "npm run build && npm run cem"
  },
  "keywords": [
    "web-components",
    "lit",
    "music",
    "piano",
    "fretboard",
    "guitar",
    "chords",
    "scales"
  ],
  "license": "MIT",
  "author": "Hubert Sablonnière",
  "repository": {
    "type": "git",
    "url": "https://github.com/hsablonniere/musiq.git"
  },
  "dependencies": {
    "@tombatossals/chords-db": "^0.5.1",
    "lit": "^3.0.0",
    "tonal": "^6.4.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@typescript/native-preview": "^7.0.0-dev.20260524.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "customElements": "custom-elements.json"
}
