{
  "name": "musiq",
  "version": "0.0.1",
  "description": "Web components for rendering musical instruments, chords, and scales",
  "type": "module",
  "sideEffects": true,
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt src/",
    "lint": "oxlint src/",
    "typecheck": "tsgo --noEmit",
    "cem": "cem analyze",
    "prepublishOnly": "npm run build && npm run cem"
  },
  "license": "MIT",
  "author": "Hubert Sablonnière",
  "repository": {
    "type": "git",
    "url": "https://github.com/hsablonniere/musiq.git"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@typescript/native-preview": "^7.0.0-dev.20260524.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "customElements": "custom-elements.json"
}
